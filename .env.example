# Gmail SMTP
# 1. Enable 2-Step Verification on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate an App Password for "Mail"
# 4. Paste it below (not your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=Netra
SMTP_ENABLED=true

# Frontend URL — used inside email links
FRONTEND_URL=http://localhost:5173

# Shared secret between netra-app and netra-notify
# Generate a strong random string: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-in-production
